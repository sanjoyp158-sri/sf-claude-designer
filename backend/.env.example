# Anthropic API Key - Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server Port
PORT=3001

# Session Secret - Use a long random string
SESSION_SECRET=your_random_session_secret_here_change_this

# Salesforce Connected App Credentials
# Create a Connected App in Salesforce Setup > App Manager
SF_CLIENT_ID=your_salesforce_connected_app_consumer_key
SF_CLIENT_SECRET=your_salesforce_connected_app_consumer_secret
